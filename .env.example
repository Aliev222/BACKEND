# Core runtime
APP_ENV=production
BOT_MODE=api

# Database (must be isolated per environment)
DATABASE_URL=postgresql://user:pass@host:5432/db_name

# Redis (must be isolated per environment)
# Preferred: separate Redis instance per environment.
# Alternative: same Redis host with different REDIS_DB index.
REDIS_URL=redis://default:password@host:6379
REDIS_DB=0

# Session/auth secret (must NOT be shared between prod and staging)
SESSION_TOKEN_SECRET=replace-with-random-secret

# Telegram-related settings (must be separate for staging)
BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_VERIFY_CHANNEL=@your_channel

# Optional hardening
REQUIRE_REDIS=1

